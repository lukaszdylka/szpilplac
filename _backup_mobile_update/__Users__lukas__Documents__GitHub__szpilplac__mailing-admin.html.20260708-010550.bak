<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mailing admin · Szpilplac</title>
<meta name="robots" content="noindex">
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@700&family=Inter:wght@400;600;800&display=swap&subset=latin,latin-ext" rel="stylesheet">
<script src="config.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
:root{--bg:#f0e8d4;--surface:#fbf7ee;--surface2:#f3ecda;--ink:#23201a;--ink2:#6a6150;--line:#c9bfa6;--green:#2f4a39;--gold:#bf8a3a;--ok:#3f8a5a;--danger:#b5482f;--sh:0 6px 18px -10px rgba(35,32,26,.4)}
[data-theme=dark]{--bg:#161310;--surface:#262018;--surface2:#2e2820;--ink:#ede5d0;--ink2:#9a907a;--line:#3d3629;--green:#4a7a56;--gold:#d4a04a;--ok:#4a9a6a;--danger:#d76a4f;--sh:0 6px 18px -10px rgba(0,0,0,.5)}
*{box-sizing:border-box}
body{margin:0;min-height:100vh;font-family:"Inter",system-ui,sans-serif;color:var(--ink);background:var(--bg);display:flex;flex-direction:column;align-items:center;padding:0 16px 40px}
a{color:var(--green);font-weight:900;text-decoration:none}
a:hover{text-decoration:underline}
button{font-family:inherit;cursor:pointer}
header,main,footer{width:100%;max-width:960px}
header{padding-top:22px;margin-bottom:14px}
.topbar{display:flex;justify-content:space-between;align-items:center;gap:12px}
h1{font-family:"Oswald";font-size:clamp(34px,7vw,52px);text-transform:uppercase;line-height:1;margin:16px 0 4px}
.sub{font-size:13px;color:var(--ink2)}
.card{background:var(--surface);border:1px solid var(--line);border-radius:16px;box-shadow:var(--sh);padding:18px;margin:12px 0}
.actions{display:flex;gap:8px;flex-wrap:wrap;margin:12px 0}
.btn{border:0;border-radius:12px;padding:11px 13px;background:var(--green);color:#fff;font-weight:900}
.btn.secondary{background:var(--surface2);color:var(--ink);border:1px solid var(--line)}
.btn.gold{background:var(--gold);color:#22170d}
.btn:disabled{opacity:.55;cursor:not-allowed}
.msg{border:1px solid var(--line);border-radius:12px;padding:12px 14px;background:var(--surface2);color:var(--ink2);font-size:13px;line-height:1.5;white-space:pre-wrap}
.msg.ok{border-color:var(--ok);color:var(--ok);background:rgba(63,138,90,.1)}
.msg.err{border-color:var(--danger);color:var(--danger);background:rgba(181,72,47,.1)}
.stats{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
.stat{background:var(--surface2);border:1px solid var(--line);border-radius:12px;padding:14px}
.stat .n{font-family:"Oswald";font-size:34px;line-height:1}
.stat .l{font-size:11px;color:var(--ink2);text-transform:uppercase;font-weight:900;letter-spacing:.04em;margin-top:4px}
.table-wrap{overflow:auto;border:1px solid var(--line);border-radius:12px;margin-top:12px}
table{width:100%;border-collapse:collapse;background:var(--surface2);font-size:13px}
th,td{padding:10px 11px;border-bottom:1px solid var(--line);text-align:left;vertical-align:top;white-space:nowrap}
th{font-size:11px;color:var(--ink2);text-transform:uppercase;letter-spacing:.04em}
tr:last-child td{border-bottom:0}
textarea{width:100%;min-height:140px;border:1px solid var(--line);border-radius:12px;padding:12px;background:#e8eef9;color:#000;font:12px ui-monospace,SFMono-Regular,Consolas,monospace}
.notice{font-size:12.5px;color:var(--ink2);line-height:1.5;background:var(--surface2);border:1px dashed var(--line);border-radius:12px;padding:12px;margin-top:10px}
.hidden{display:none!important}
footer{text-align:center;color:var(--ink2);font-size:12px;margin-top:18px}
@media(max-width:640px){.stats{grid-template-columns:1fr}.topbar{align-items:flex-start;flex-direction:column}}
</style>
</head>
<body>
<header>
  <div class="topbar">
    <a href="index.html">← Szpilplac</a>
    <div><a href="konto.html">Mój profil</a> · <a href="stats.html">Stats</a></div>
  </div>
  <h1>Mailing admin</h1>
  <div class="sub">Lista osób, które dobrowolnie zaznaczyły zgodę marketingową.</div>
</header>

<main>
  <div id="msg" class="msg">Ładuję...</div>

  <section id="panel" class="card hidden">
    <div class="stats">
      <div class="stat"><div class="n" id="countAll">0</div><div class="l">zgód mailingowych</div></div>
      <div class="stat"><div class="n" id="countSlaskie">0</div><div class="l">śląskie</div></div>
      <div class="stat"><div class="n" id="countCities">0</div><div class="l">miejscowości</div></div>
    </div>

    <div class="actions">
      <button class="btn" id="refreshBtn">Odśwież</button>
      <button class="btn secondary" id="copyEmailsBtn">Kopiuj e-maile</button>
      <button class="btn secondary" id="copyBccBtn">Kopiuj BCC</button>
      <button class="btn gold" id="csvBtn">Pobierz CSV</button>
    </div>

    <div class="notice">
      Ten panel <b>nie wysyła maili</b>. Daje bezpieczną listę osób ze zgodą. Na małą skalę możesz zrobić eksport, a właściwy automat wysyłki podepniemy później. Nie wysyłaj mailingu osobom bez zgody.
    </div>

    <div class="card" style="box-shadow:none;margin-top:14px">
      <h2 style="font-family:Oswald;text-transform:uppercase;margin:0 0 8px">Treść do skopiowania</h2>
      <textarea id="emailsBox" readonly></textarea>
    </div>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>E-mail</th>
            <th>Login</th>
            <th>Województwo</th>
            <th>Miejscowość</th>
            <th>Data zgody</th>
          </tr>
        </thead>
        <tbody id="rows"></tbody>
      </table>
    </div>
  </section>
</main>

<footer>
  Szpilplac · Familock · <a href="mailing.html">zasady mailingu</a>
</footer>

<script>
"use strict";
console.info("Szpilplac mailing-admin.html v20");

var AUTH_STORAGE_KEY="szpilplac-auth-v05";
var sb=null;
var contacts=[];

function $(id){return document.getElementById(id);}
function esc(v){return String(v==null?"":v).replace(/[&<>"']/g,function(ch){return {"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"}[ch];});}
function setMsg(text,type){$("msg").textContent=text;$("msg").className="msg"+(type?" "+type:"");$("msg").classList.remove("hidden");}
function hideMsg(){$("msg").classList.add("hidden");}
function dateFmt(v){return v?new Date(v).toLocaleString("pl-PL"):"—";}
function csvEscape(v){v=String(v==null?"":v);return /[",\n;]/.test(v)?'"'+v.replace(/"/g,'""')+'"':v;}

function initTheme(){
  try{document.documentElement.setAttribute("data-theme",localStorage.getItem("szpilplac_theme")||"light");}catch(e){}
}

function initSupabase(){
  var cfg=window.SZPILPLAC_CONFIG||{};
  if(!cfg.SUPABASE_URL||!cfg.SUPABASE_ANON_KEY){setMsg("Brak config.js albo danych Supabase.","err");return false;}
  if(!window.supabase){setMsg("Nie załadowano Supabase JS.","err");return false;}
  sb=window.supabase.createClient(cfg.SUPABASE_URL,cfg.SUPABASE_ANON_KEY,{
    auth:{storageKey:AUTH_STORAGE_KEY,detectSessionInUrl:false,persistSession:true,autoRefreshToken:true}
  });
  return true;
}

async function loadContacts(){
  setMsg("Pobieram listę mailingową...");
  $("panel").classList.add("hidden");

  try{
    var sessionRes=await sb.auth.getSession();
    if(!sessionRes.data.session){
      setMsg("Najpierw zaloguj się na konto admina w konto.html, potem wróć tutaj.","err");
      return;
    }

    var res=await sb.rpc("szpilplac_admin_mailing_contacts");
    if(res.error)throw res.error;

    contacts=res.data||[];
    render();
    hideMsg();
    $("panel").classList.remove("hidden");
  }catch(err){
    setMsg("Nie udało się pobrać listy. Możliwe, że nie jesteś adminem albo nie uruchomiono SQL v20.\n\n"+(err.message||err),"err");
  }
}

function render(){
  $("countAll").textContent=contacts.length;
  $("countSlaskie").textContent=contacts.filter(function(c){return c.voivodeship==="śląskie";}).length;
  var cities={};
  contacts.forEach(function(c){if(c.city)cities[String(c.city).toLowerCase()]=1;});
  $("countCities").textContent=Object.keys(cities).length;

  var emails=contacts.map(function(c){return c.email;}).filter(Boolean);
  $("emailsBox").value=emails.join(", ");

  $("rows").innerHTML=contacts.map(function(c){
    return "<tr>"+
      "<td>"+esc(c.email)+"</td>"+
      "<td>"+esc(c.display_name||c.login||"—")+"</td>"+
      "<td>"+esc(c.voivodeship||"—")+"</td>"+
      "<td>"+esc(c.city||"—")+"</td>"+
      "<td>"+esc(dateFmt(c.marketing_consent_at))+"</td>"+
    "</tr>";
  }).join("");
}

async function copyText(txt,label){
  try{
    await navigator.clipboard.writeText(txt);
    setMsg(label,"ok");
  }catch(e){
    $("emailsBox").value=txt;
    $("emailsBox").focus();
    $("emailsBox").select();
    setMsg("Nie udało się skopiować automatycznie. Tekst jest zaznaczony w polu.","err");
  }
}

function downloadCsv(){
  var header=["email","login","display_name","voivodeship","city","marketing_consent_at","account_created_at"];
  var lines=[header.join(";")].concat(contacts.map(function(c){
    return header.map(function(k){return csvEscape(c[k]);}).join(";");
  }));
  var blob=new Blob([lines.join("\n")],{type:"text/csv;charset=utf-8"});
  var url=URL.createObjectURL(blob);
  var a=document.createElement("a");
  a.href=url;
  a.download="szpilplac-mailing-"+new Date().toISOString().slice(0,10)+".csv";
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  URL.revokeObjectURL(url);
}

$("refreshBtn").addEventListener("click",loadContacts);
$("copyEmailsBtn").addEventListener("click",function(){
  copyText(contacts.map(function(c){return c.email;}).filter(Boolean).join(", "),"Skopiowano e-maile.");
});
$("copyBccBtn").addEventListener("click",function(){
  copyText("bcc:"+contacts.map(function(c){return c.email;}).filter(Boolean).join(", "),"Skopiowano listę BCC.");
});
$("csvBtn").addEventListener("click",downloadCsv);

initTheme();
if(initSupabase())loadContacts();
</script>
</body>
</html>
