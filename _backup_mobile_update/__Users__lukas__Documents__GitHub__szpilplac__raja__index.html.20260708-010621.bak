    <button type="button" class="cookie-btn cookie-btn--ghost" id="cookieRequiredBtn">Akceptuję tylko wymagane</button>
    <button type="button" class="cookie-btn cookie-btn--solid" id="cookieAllBtn">Akceptuję wszystkie</button>
  </div>
</div>

<div id="helpScrim" class="scrim">
  <div class="modal">
    <button id="helpClose" class="x" type="button" aria-label="Zamknij">×</button>
    <h2 id="howTitle">Jak grać</h2>
    <p id="howBody"></p>
  </div>
</div>

<div id="statScrim" class="scrim">
  <div class="modal">
    <button id="statClose" class="x" type="button" aria-label="Zamknij">×</button>
    <h2 id="statTitle">Statystyki</h2>
    <div id="statBody" class="stats-body"></div>
  </div>
</div>

<div id="settScrim" class="scrim">
  <div class="modal">
    <button id="settClose" class="x" type="button" aria-label="Zamknij">×</button>
    <h2 id="settTitle">Ustawienia</h2>
    <div class="settings-body">
      <div class="sett-row">
        <div><div id="animLabel" class="sett-label">Animacje</div><div id="animSub" class="sett-sub">Ruch kafelków i krótkie efekty.</div></div>
        <div class="seg"><button id="animOn" type="button">Wł.</button><button id="animOff" type="button">Wył.</button></div>
      </div>
      <div class="sett-row">
        <div><div id="soundLabel" class="sett-label">Dźwięki</div><div id="soundSub" class="sett-sub">Ciche kliknięcia i sygnały po próbie.</div></div>
        <div class="seg"><button id="soundOn" type="button">Wł.</button><button id="soundOff" type="button">Wył.</button></div>
      </div>
      <div class="sett-row">
        <div><div id="cbLabel" class="sett-label">Kolory dla daltonistów</div><div id="cbSub" class="sett-sub">Alternatywne kolory jak w Słōwku i Kłōdce.</div></div>
        <div class="seg"><button id="cbOn" type="button">Wł.</button><button id="cbOff" type="button">Wył.</button></div>
      </div>
    </div>
  </div>
</div>

<div id="toast" class="toast"></div>

<script>
(function(){
"use strict";

var SUPABASE_URL=(window.SZPILPLAC_CONFIG&&window.SZPILPLAC_CONFIG.SUPABASE_URL)||window.SUPABASE_URL||"";
var SUPABASE_ANON_KEY=(window.SZPILPLAC_CONFIG&&window.SZPILPLAC_CONFIG.SUPABASE_ANON_KEY)||window.SUPABASE_ANON_KEY||"";
var TEST_PASSWORD="starzik";
var MAX_TRIES=4;

var LANG_KEY="familock_lang", THEME_KEY="szpilplac_theme", ANIM_KEY="zorta_anim", SOUND_KEY="zorta_sound", CB_KEY="zorta_cb";
var ZORTA_STATS_KEY="zorta_daily_stats_v1";
var EPOCH_UTC=Date.UTC(2026,6,4);

var store={
  get:function(k){try{return localStorage.getItem(k);}catch(e){return null;}},
  set:function(k,v){try{localStorage.setItem(k,v);}catch(e){}}
};

var IS_TESTER=(function(){try{return new URLSearchParams(location.search).get("test")===TEST_PASSWORD;}catch(e){return false;}})();

function warsawDay(d){
  var p=new Intl.DateTimeFormat("en-CA",{timeZone:"Europe/Warsaw",year:"numeric",month:"2-digit",day:"2-digit"}).formatToParts(d),o={};
  p.forEach(function(x){if(x.type!=="literal")o[x.type]=Number(x.value);});
  return Date.UTC(o.year,o.month-1,o.day);
}
function todayIndexRaw(){return Math.floor((warsawDay(new Date())-EPOCH_UTC)/86400000);}
function todayIndex(){return Math.max(0,todayIndexRaw());}
var TODAY_IDX_RAW=todayIndexRaw();
var RAJA_STARTED=(TODAY_IDX_RAW>=0);
var TODAY_IDX=todayIndex();
var currentDay=TODAY_IDX;

window.TODAY_IDX=TODAY_IDX;
window.TODAY_IDX_RAW=TODAY_IDX_RAW;
window.RAJA_STARTED=RAJA_STARTED;
window.currentDay=currentDay;
window.MAX_TRIES=MAX_TRIES;
window.IS_TESTER=IS_TESTER;

function loadConfig(){return (SUPABASE_URL&&SUPABASE_ANON_KEY)?Promise.resolve():Promise.reject(new Error("config"));}
function rpc(fn,args){
  return fetch(SUPABASE_URL+"/rest/v1/rpc/"+fn,{method:"POST",
    headers:{"Content-Type":"application/json","Accept":"application/json","apikey":SUPABASE_ANON_KEY,"Authorization":"Bearer "+SUPABASE_ANON_KEY},
    body:JSON.stringify(args||{})
  }).then(function(r){
    return r.text().then(function(t){
      var data=null;try{data=t?JSON.parse(t):null;}catch(e){data=t;}
      if(!r.ok){var msg=(data&&(data.message||data.details||data.hint||data.code))||t||r.status;throw new Error(fn+" "+r.status+" "+msg);}
      return data;
    });
  });
}
function postEventPayload(p){
  return fetch(SUPABASE_URL+"/rest/v1/szpilplac_events",{method:"POST",
    headers:{"Content-Type":"application/json","apikey":SUPABASE_ANON_KEY,"Authorization":"Bearer "+SUPABASE_ANON_KEY,"Prefer":"return=minimal"},
    body:JSON.stringify(p)
  });
}
function eventCorePayload(p){
  var q={game:p.game,puzzle_no:p.puzzle_no,puzzle_word:p.puzzle_word,won:!!p.won,tries:p.tries,lang:p.lang,mode:p.mode};
  if(p.errors!==undefined)q.errors=p.errors;
  return q;
}
function okEvent(r){if(r.ok)return true;return r.text().then(function(t){throw new Error("event "+r.status+" "+t);});}
function trackEvent(p){
  var core=eventCorePayload(p),ext={};Object.keys(core).forEach(function(k){ext[k]=core[k];});
  ext.hint_used=!!p.hint_used;
  postEventPayload(ext).then(okEvent).catch(function(err1){
    postEventPayload(core).then(okEvent).catch(function(err2){console.warn("Raja event not saved",err1,err2);});
  });
}

var S={
  pl:{
    tag:"Codzienna śląska zagadka — poukładaj",check:"Sprawdź",
    triesLab:"prób",win:"Poukładane!",lose:"Nie tym razem",
    winSub:["Perfekcyjnie!","Brawo!","Idealnie!","Ekstra!"],
    loseSub:"Tak wyglądała właściwa kolejność:",
    correctOrder:"Właściwa kolejność:",share:"Podziel się wynikiem",copied:"Skopiowano do schowka",
    howT:"Jak grać",
    how:"Ułóż pięć rzeczy we właściwej kolejności.<br><br>Przeciągnij kafelek i puść go w nowym miejscu. Możesz też stuknąć jeden kafelek, potem drugi, żeby zamienić je miejscami. Strzałki ▲▼ przesuwają kafelek o jedno miejsce.<br><br>Po każdej próbie zielone pozycje zostają trafione. Masz 4 próby. Po dwóch próbach możesz użyć jednej podpowiedzi — gra pokaże jeden element i jego właściwe miejsce.",
    day:"Dzień",today:"dzisioj",tester:"tryb testera",load:"Ładowanie…",cat:"Kategoria",sortBy:"Ułóż według",
    err:"Nie udało się wczytać zagadki. Spróbuj odświeżyć.",
    settings:"Ustawienia",on:"Wł.",off:"Wył.",anim:"Animacje",animSub:"Ruch kafelków i krótkie efekty.",sound:"Dźwięki",soundSub:"Ciche kliknięcia i sygnały po próbie.",cb:"Kolory dla daltonistów",cbSub:"Alternatywne kolory jak w Słōwku i Kłōdce.",
    hintBtn:"Pokaż podpowiedź",hintText:"Podpowiedź: <b>{name}</b> powinno być na miejscu <b>{pos}</b>.",hintPlace:"miejsce {pos}",hintErr:"Nie udało się pobrać podpowiedzi.",
    stats:"Statystyki",played:"Rozegrane",wins:"Wygrane",winPct:"Skuteczność",streak:"Seria",bestStreak:"Najlepsza seria",avgTries:"Śr. prób",hintsUsed:"Podpowiedzi",dist:"Rozkład prób",noStats:"Nie masz jeszcze statystyk Rai.",clearStats:"Wyczyść statystyki Rai",statsNote:"Statystyki są zapisane lokalnie w tej przeglądarce.",sharePrompt:"Poukładasz lepiej?"
  },
  sl:{
    tag:"Codziynno ślōnsko zagodka — poukłŏdej",check:"Wejrzij",
    triesLab:"prōb",win:"Poukłŏdane!",lose:"Niy tym razym",
    winSub:["Perfekt!","Brawo!","Idealnie!","Ekstra!"],
    loseSub:"Tak szła dobro kolejność:",
    correctOrder:"Dobro kolejność:",share:"Podziel sie wynikym",copied:"Skopiowane",
    howT:"Jak grać",
    how:"Poukłŏdej piyńć rzeczy po dobrym porządku.<br><br>Przeciōngnij kafelek i puść go w nowym miyjscu. Możesz tyż klyknōńć jedyn kafelek, potym drugi, coby je zamiynić. Strzałki ▲▼ przesuwajōm kafelek o jedno miyjsce.<br><br>Po kożdej prōbie zielōne pozycyje sōm trefiōne. Mŏsz 4 prōby. Po dwóch prōbach możesz użyć jednej podpowiydzi — szpil pokaże jedyn elymynt i jego dobre miyjsce.",
    day:"Dziyń",today:"dzisioj",tester:"tryb testera",load:"Ładowanie…",cat:"Kategoryjo",sortBy:"Poukłŏdej wedle",
    err:"Niy szło wczytać zagodki. Sprōbuj ôdświyżyć.",
    settings:"Sztelōnki",on:"Wł.",off:"Wył.",anim:"Animacyje",animSub:"Ruch kafelkōw i krōtkie efekty.",sound:"Głos",soundSub:"Ciche klikniyncia i sygnały po prōbie.",cb:"Kolory dlŏ daltonistōw",cbSub:"Inaksze kolory jak w Słōwku i Kłōdce.",
    hintBtn:"Pokoż podpowiydź",hintText:"Podpowiydź: <b>{name}</b> mŏ być na miyjscu <b>{pos}</b>.",hintPlace:"miyjsce {pos}",hintErr:"Niy szło pobrać podpowiydzi.",
    stats:"Statystyki",played:"Rozegrane",wins:"Wygrane",winPct:"Skuteczność",streak:"Seryjo",bestStreak:"Nojlepszo seryjo",avgTries:"Strz. prōb",hintsUsed:"Podpowiydzi",dist:"Rozkład prōb",noStats:"Niy mosz jeszcze statystyk Rai.",clearStats:"Wyczyść statystyki Rai",statsNote:"Statystyki sōm spamiyntane lokalnie w tyj przeglōndarce.",sharePrompt:"Poukłŏdosz lepij?"
  }
};
var lang=(store.get(LANG_KEY)==="szl"||store.get(LANG_KEY)==="SL")?"sl":"pl";
function L(){return S[lang];}

var DIR={
  "liczba mieszkańców":{a:"od najmniej ludnego → do najludniejszego",d:"od najludniejszego → do najmniej ludnego"},
  "powierzchnia miasta":{a:"od najmniejszego → do największego",d:"od największego → do najmniejszego"},
  "odległość od Katowic":{a:"od najbliżej Katowic → do najdalej",d:"od najdalej od Katowic → do najbliżej"},
  "położenie: południe–północ":{a:"od najdalej na południe → na północ",d:"od najdalej na północ → na południe"},
  "położenie: zachód–wschód":{a:"od najdalej na zachód → na wschód",d:"od najdalej na wschód → na zachód"},
  "rok wydarzenia":{a:"od najdawniejszego → do najnowszego",d:"od najnowszego → do najdawniejszego"},
  "rok założenia klubu":{a:"od najstarszego klubu → do najmłodszego",d:"od najmłodszego klubu → do najstarszego"},
  "orientacyjna kaloryczność porcji":{a:"od lżejszego → do bardziej kalorycznego",d:"od bardziej kalorycznego → do lżejszego"},
  "liczba liter w słowie śląskim":{a:"od najkrótszego → do najdłuższego",d:"od najdłuższego → do najkrótszego"},
  "śląski odpowiednik A–Z":{a:"według śląskiego odpowiednika A–Z",d:"według śląskiego odpowiednika Z–A"},
  "śląski odpowiednik Z–A":{a:"według śląskiego odpowiednika A–Z",d:"według śląskiego odpowiednika Z–A"},
  "polskie znaczenie A–Z":{a:"według polskiego znaczenia A–Z",d:"według polskiego znaczenia Z–A"},
  "polskie znaczenie Z–A":{a:"według polskiego znaczenia A–Z",d:"według polskiego znaczenia Z–A"},
  "słowo śląskie A–Z":{a:"alfabetycznie A–Z",d:"alfabetycznie Z–A"}
};
function dirText(kryt,kier){var m=DIR[kryt]||{a:"od pierwszego → do ostatniego",d:"od ostatniego → do pierwszego"};return kier==="rosnaco"?m.a:m.d;}
function setPuzzleHeader(m){
  $("eyebrow").textContent=(L().cat+": "+m.kategoria).toUpperCase();
  $("crit").textContent=L().sortBy+": "+m.kryterium.charAt(0).toLowerCase()+m.kryterium.slice(1);
  $("dirText").textContent=dirText(m.kryterium,m.kierunek);
  $("dirArrow").textContent=(m.kierunek==="rosnaco")?"↓":"↑";
}

var meta=null, order=[], guessHistory=[], status="playing", selIdx=-1, revealMap=null, revealOrder=null, hintData=null;
var dragFrom=-1,dragTo=-1,dragMoved=false,dragStartX=0,dragStartY=0,dragOffsetX=0,dragOffsetY=0,dragGhost=null,suppressClick=false;
var DEMO=false;

window.meta=meta;
window.order=order;
window.guessHistory=guessHistory;
window.status=status;
window.hintData=hintData;

function syncGlobals(){
  window.currentDay=currentDay;
  window.TODAY_IDX=TODAY_IDX;
window.TODAY_IDX_RAW=TODAY_IDX_RAW;
window.RAJA_STARTED=RAJA_STARTED;
  window.meta=meta;
  window.order=order;
  window.guessHistory=guessHistory;
  window.status=status;
  window.hintData=hintData;
}

function $(id){return document.getElementById(id);}
function showNotice(html){var n=$("notice");if(!n)return;n.innerHTML=html;n.style.display="block";}
function hideNotice(){var n=$("notice");if(!n)return;n.style.display="none";}
function toast(t){var el=$("toast");el.textContent=t;el.classList.add("show");setTimeout(function(){el.classList.remove("show");},1900);}

function dayKey(d){return "zorta_daily_d"+d;}
function loadState(d){try{return JSON.parse(store.get(dayKey(d))||"null");}catch(e){return null;}}
function saveState(d,s){store.set(dayKey(d),JSON.stringify(s));}
function clearState(d){try{store.set(dayKey(d),"");}catch(e){}}
function sameMembers(a,b){
  if(!Array.isArray(a)||!Array.isArray(b)||a.length!==b.length)return false;
  return a.slice().sort().join("\u0001")===b.slice().sort().join("\u0001");
}
function sanitizeState(st,pozycje){
  if(!st||!Array.isArray(st.order)||!sameMembers(st.order,pozycje))return null;
  var h=Array.isArray(st.history)?st.history:[];
  h=h.filter(function(m){return Array.isArray(m)&&m.length===pozycje.length;});
  var stStatus=(st.status==="won"||st.status==="lost")?st.status:"playing";
  if(stStatus==="playing"&&h.length>=MAX_TRIES)return null;
  if(h.length>MAX_TRIES)h=h.slice(0,MAX_TRIES);
  var hd=(st.hintData&&st.hintData.name&&st.hintData.pos)?{name:st.hintData.name,pos:st.hintData.pos}:null;
  return {order:st.order.slice(),history:h,status:stStatus,hintData:hd};
}
function persist(){saveState(currentDay,{order:order,history:guessHistory,status:status,hintData:hintData});syncGlobals();}
function loadJSON(k){try{return JSON.parse(store.get(k)||"null");}catch(e){return null;}}
function saveJSON(k,v){store.set(k,JSON.stringify(v));}
function emptyStats(){return {version:2,days:{}};}
function getZortaStats(){var s=loadJSON(ZORTA_STATS_KEY);return s&&s.days?s:emptyStats();}
function recalcZortaStats(st){
  var keys=Object.keys(st.days||{}).map(function(k){return +k;}).filter(function(n){return !isNaN(n);}).sort(function(a,b){return a-b;});
  var played=keys.length,wins=0,hints=0,dist={"1":0,"2":0,"3":0,"4":0,"X":0};
  keys.forEach(function(k){var r=st.days[k]||{};if(r.won)wins++;if(r.hintUsed)hints++;var d=r.won?String(r.tries||"X"):"X";if(!dist[d])dist[d]=0;dist[d]++;});
  var streak=0,best=0,run=0,last=null;
  keys.forEach(function(k){var r=st.days[k]||{};if(r.won && (last===null || k===last+1)){run++;}else if(r.won){run=1;}else{run=0;}if(run>best)best=run;last=k;});
  if(keys.length){var k=TODAY_IDX;while(st.days[k]&&st.days[k].won){streak++;k--;}}
  var avg="–";if(wins){var sum=0,c=0;keys.forEach(function(k){var r=st.days[k]||{};if(r.won&&r.tries){sum+=+r.tries;c++;}});avg=c?(sum/c).toFixed(1):"–";}
  return {played:played,wins:wins,winPct:played?Math.round(wins/played*100)+"%":"–",streak:streak,best:best,avg:avg,hints:hints,dist:dist};
}
function recordLocalStats(won){
  if(IS_TESTER&&currentDay>TODAY_IDX)return;
  var st=getZortaStats(),dk=String(currentDay);
  if(st.days[dk])return;
  st.days[dk]={won:!!won,tries:won?guessHistory.length:null,hintUsed:!!hintData,at:new Date().toISOString(),category:meta?meta.kategoria:""};
  saveJSON(ZORTA_STATS_KEY,st);
}
function statCard(n,l){return '<div class="stat-card"><div class="n">'+n+'</div><div class="l">'+l+'</div></div>';}
function renderStatsModal(){
  var st=getZortaStats(),m=recalcZortaStats(st),s=L();
  if(!m.played){$("statBody").innerHTML='<p class="stat-note">'+s.noStats+'</p>';return;}
  var max=0;Object.keys(m.dist).forEach(function(k){if(m.dist[k]>max)max=m.dist[k];});
  var dist=["1","2","3","4","X"].map(function(k){
    var v=m.dist[k]||0,w=max?Math.max(8,Math.round(v/max*100)):8;
    return '<div class="stat-dist-row"><div class="stat-dist-i">'+k+'</div><div class="stat-dist-bar-wrap"><div class="stat-dist-bar" style="width:'+w+'%">'+v+'</div></div></div>';
  }).join("");
  var shareHtml=(status!=="playing"&&guessHistory.length)?'<button class="stat-share" id="statShareBtn">'+s.share+'</button>':"";
  $("statBody").innerHTML='<div class="stats-grid">'+
    statCard(m.played,s.played)+statCard(m.wins,s.wins)+statCard(m.winPct,s.winPct)+statCard(m.avg,s.avgTries)+
    statCard(m.streak,s.streak)+statCard(m.best,s.bestStreak)+statCard(m.hints,s.hintsUsed)+
    '</div><div><h3 style="font-family:Oswald;text-transform:uppercase;font-size:15px;margin:2px 0 8px;color:var(--ink2)">'+s.dist+'</h3><div class="stat-dist">'+dist+'</div></div>'+shareHtml+'<p class="stat-note">'+s.statsNote+'</p><button class="stat-clear" id="clearZortaStats">'+s.clearStats+'</button>';
  var sb=$("statShareBtn");if(sb)sb.addEventListener("click",function(){share();});
  var c=$("clearZortaStats");if(c)c.addEventListener("click",function(){store.set(ZORTA_STATS_KEY,JSON.stringify(emptyStats()));renderStatsModal();});
}

function lastMask(){return guessHistory.length?guessHistory[guessHistory.length-1]:null;}
function renderList(){
  var ul=$("list");ul.innerHTML="";
  var locked=(status!=="playing");
  var mask=lastMask();
  order.forEach(function(name,i){
    var li=document.createElement("li");li.className="row";li.dataset.index=i;
    if(!locked)li.className+=" can-drag";
    if(selIdx===i)li.className+=" sel";
    if(mask&&mask[i])li.className+=" fixed";
    if(status==="playing"&&hintData&&hintData.name===name)li.className+=" hinted";
    var fixed=!!(mask&&mask[i]);
    var hintTag=(status==="playing"&&hintData&&hintData.name===name)?'<span class="hinttag">'+L().hintPlace.replace("{pos}",hintData.pos)+'</span>':'';
    var html='<div class="rank">'+(i+1)+'</div><div class="name">'+name+'</div>'+hintTag;
    if(!locked){
      html+='<div class="arrows"><button data-up="'+i+'" '+(i===0?'disabled':'')+'>▲</button><button data-down="'+i+'" '+(i===order.length-1?'disabled':'')+'>▼</button></div>';
    }else if(fixed){html+='<div class="tick">✓</div>';}
    li.innerHTML=html;
    if(!locked){
      // Mobile-first v130: układanie wyłącznie strzałkami.
      // Wyłączone: tap-to-swap i drag/drop, bo na telefonach dawały za dużo sposobów układania.
    }
    ul.appendChild(li);
  });
  ul.querySelectorAll("[data-up]").forEach(function(b){b.addEventListener("click",function(e){e.stopPropagation();move(+b.dataset.up,-1);});});
  ul.querySelectorAll("[data-down]").forEach(function(b){b.addEventListener("click",function(e){e.stopPropagation();move(+b.dataset.down,1);});});
}
function removeDragGhost(){if(dragGhost&&dragGhost.parentNode)dragGhost.parentNode.removeChild(dragGhost);dragGhost=null;}
function clearDragClasses(){document.querySelectorAll(".row.drag-source,.row.drop-target").forEach(function(el){el.classList.remove("drag-source","drop-target");});removeDragGhost();}
function makeDragGhost(li,e){
  removeDragGhost();
  var rect=li.getBoundingClientRect();dragOffsetX=e.clientX-rect.left;dragOffsetY=e.clientY-rect.top;
  dragGhost=li.cloneNode(true);dragGhost.className="row drag-ghost";dragGhost.style.width=rect.width+"px";dragGhost.style.height=rect.height+"px";
  document.body.appendChild(dragGhost);positionDragGhost(e);li.classList.add("drag-source");
}
function positionDragGhost(e){if(!dragGhost)return;dragGhost.style.left=(e.clientX-dragOffsetX)+"px";dragGhost.style.top=(e.clientY-dragOffsetY)+"px";}
function reorder(from,to){if(from<0||to<0||from===to||from>=order.length||to>=order.length)return;var item=order.splice(from,1)[0];order.splice(to,0,item);selIdx=-1;persist();playSound("drop");renderList();}
function dragOverIndex(x,y){
  var rows=[].slice.call(document.querySelectorAll("#list .row"));
  if(!rows.length)return -1;
  for(var r=0;r<rows.length;r++){var rect=rows[r].getBoundingClientRect();if(y>=rect.top&&y<=rect.bottom)return +rows[r].dataset.index;}
  var first=rows[0].getBoundingClientRect(),last=rows[rows.length-1].getBoundingClientRect();
  if(y<first.top)return 0;if(y>last.bottom)return rows.length-1;return -1;
}
function markDropTarget(i){document.querySelectorAll(".row.drop-target").forEach(function(el){el.classList.remove("drop-target");});var row=document.querySelector('#list .row[data-index="'+i+'"]');if(row)row.classList.add("drop-target");}
function attachDrag(li,i){
  li.addEventListener("pointerdown",function(e){if(e.button!=null&&e.button!==0)return;if(e.target.closest(".arrows"))return;dragFrom=i;dragTo=i;dragMoved=false;dragStartX=e.clientX;dragStartY=e.clientY;try{li.setPointerCapture&&li.setPointerCapture(e.pointerId);}catch(err){}});
  li.addEventListener("pointermove",function(e){
    if(dragFrom!==i)return;
    var dist=Math.abs(e.clientX-dragStartX)+Math.abs(e.clientY-dragStartY);
    if(!dragMoved&&dist>7){dragMoved=true;makeDragGhost(li,e);}
    if(dragMoved){e.preventDefault();positionDragGhost(e);var target=dragOverIndex(e.clientX,e.clientY);if(target>=0){dragTo=target;markDropTarget(target);}}
  });
  li.addEventListener("pointerup",function(e){
    if(dragFrom===i&&dragMoved){e.preventDefault();suppressClick=true;reorder(dragFrom,dragTo);setTimeout(function(){suppressClick=false;dragMoved=false;},180);}
    else{setTimeout(function(){dragMoved=false;},0);}
    try{li.releasePointerCapture&&li.releasePointerCapture(e.pointerId);}catch(err){}
    clearDragClasses();dragFrom=-1;
  });
  li.addEventListener("pointercancel",function(){clearDragClasses();dragFrom=-1;dragMoved=false;setTimeout(function(){suppressClick=false;},80);});
}
function pick(i){if(status!=="playing")return;if(selIdx===-1){selIdx=i;}else if(selIdx===i){selIdx=-1;}else{var t=order[selIdx];order[selIdx]=order[i];order[i]=t;selIdx=-1;persist();playSound("move");}renderList();}
function move(i,dir){var j=i+dir;if(j<0||j>=order.length)return;var t=order[i];order[i]=order[j];order[j]=t;selIdx=-1;persist();playSound("move");renderList();}

function renderAttempts(){
  var box=$("attempts");box.innerHTML="";box.style.display=(status==="playing")?"flex":"none";
  var used=Math.min(guessHistory.length,MAX_TRIES);
  for(var i=0;i<MAX_TRIES;i++){var d=document.createElement("span");d.className="dot"+(i<used?" used":"");box.appendChild(d);}
  var lab=document.createElement("span");lab.className="lab";lab.textContent=Math.max(0,MAX_TRIES-guessHistory.length)+" "+L().triesLab;box.appendChild(lab);
  renderHint();
}
function fmtVal(v,unit){return String(v||"");}
function formatHintText(h){return L().hintText.replace("{name}",h.name).replace("{pos}",h.pos);}
function hintWaitText(){if(lang==="sl")return guessHistory.length===1?"Podpowiydź po jeszcze 1 prōbie":"Podpowiydź po 2 prōbach";return guessHistory.length===1?"Podpowiedź po jeszcze 1 próbie":"Podpowiedź po 2 próbach";}
function renderHint(){
  var hb=$("hintBar");if(!hb)return;
  var btn=$("hintBtn"),msg=$("hintMsg");
  if(status!=="playing"){hb.style.display="none";return;}
  hb.style.display="flex";
  if(hintData){btn.style.display="none";msg.style.display="block";msg.innerHTML=formatHintText(hintData);return;}
  msg.style.display="none";msg.innerHTML="";btn.style.display="inline-flex";
  if(guessHistory.length>=2){btn.disabled=false;btn.textContent=L().hintBtn;}
  else{btn.disabled=true;btn.textContent=hintWaitText();}
}
function chooseHint(correctOrder){
  if(!Array.isArray(correctOrder)||!correctOrder.length)return null;
  for(var i=0;i<correctOrder.length;i++){if(order[i]!==correctOrder[i])return {name:correctOrder[i],pos:i+1};}
  return {name:correctOrder[0],pos:1};
}
function useHint(){
  if(status!=="playing"||hintData||guessHistory.length<2)return;
  var btn=$("hintBtn");if(btn)btn.disabled=true;
  function done(h){if(!h){toast(L().hintErr);renderHint();return;}hintData=h;persist();playSound("hint");renderList();renderHint();}
  rpc("zorta_daily_reveal",{p_day:currentDay}).then(function(rv){done(chooseHint(rv.kolejnosc));}).catch(function(){toast(L().hintErr);renderHint();});
}
function showResult(won){
  $("attempts").style.display="none";$("checkBtn").style.display="none";
  var r=$("result");r.classList.add("show");
  $("resTitle").textContent=won?L().win:L().lose;
  $("resSub").textContent=won?L().winSub[Math.floor(Math.random()*L().winSub.length)]:L().loseSub;
  var ul=$("resList");ul.innerHTML="";
  var corr=revealOrder||order;
  corr.forEach(function(name,i){
    var li=document.createElement("li");li.className="row";
    var val=(revealMap&&revealMap[name]!=null)?'<span class="val">'+fmtVal(revealMap[name],meta.jednostka)+'</span>':'';
    li.innerHTML='<div class="rank">'+(i+1)+'</div><div class="name">'+name+'</div>'+val;
    ul.appendChild(li);
  });
  $("resSrc").textContent="";
}
function check(){
  if(status!=="playing")return;
  if(guessHistory.length>=MAX_TRIES){guessHistory=[];persist();renderAttempts();}
  $("checkBtn").disabled=true;playSound("check");
  rpc("zorta_daily_guess",{p_day:currentDay,p_order:order}).then(function(res){
    $("checkBtn").disabled=false;
    if(res&&res.blad){toast("Błąd listy: "+res.blad);return;}
    guessHistory.push(res.maska);
    if(res.ok){
      status="won";revealMap=res.wartosci;revealOrder=res.kolejnosc;persist();finishUp(true);
    }else if(guessHistory.length>=MAX_TRIES){
      status="lost";persist();
      rpc("zorta_daily_reveal",{p_day:currentDay}).then(function(rv){revealMap=rv.wartosci;revealOrder=rv.kolejnosc;finishUp(false);}).catch(function(){finishUp(false);});
    }else{persist();renderList();renderAttempts();}
  }).catch(function(err){
    $("checkBtn").disabled=false;
    console.warn("Raja daily guess error",err);
    showNotice("<b>Błąd sprawdzania</b><br>Sprawdź, czy w Supabase został uruchomiony SQL <code>supabase-raja-daily-schema-seed-v88.sql</code>.");
    toast("Błąd sprawdzania.");
  });
}

function scoreRajaAccount(won,tries,hintUsed){
  tries=Math.max(1,Math.min(MAX_TRIES,Number(tries||MAX_TRIES)));
  if(!won)return 5;
  var table=[150,120,90,60];
  var score=table[tries-1]||60;
  if(hintUsed)score=Math.max(20,score-25);
  return score;
}
function rajaAccountPayload(won){
  var tries=Math.max(1,Number(guessHistory&&guessHistory.length?guessHistory.length:MAX_TRIES));
  return {
    game:"zorta",
    mode:"daily",
    puzzleNo:currentDay+1,
    puzzle_no:currentDay+1,
    dayIndex:currentDay,
    won:!!won,
    tries:tries,
    errors:Math.max(0,tries-(won?1:0)),
    score:scoreRajaAccount(!!won,tries,!!hintData),
    isCurrent:!!(RAJA_STARTED && currentDay===TODAY_IDX && TODAY_IDX_RAW>=0),
    hintUsed:!!hintData,
    finishedAt:new Date().toISOString()
  };
}
function notifyRajaAccountFinished(won){
  try{
    var data=rajaAccountPayload(won);
    window.__SZP_LAST_RAJA_RESULT=data;
    if(typeof CustomEvent==="function"){
      window.dispatchEvent(new CustomEvent("szpilplac:raja-finished",{detail:data}));
    }else{
      var ev=document.createEvent("CustomEvent");
      ev.initCustomEvent("szpilplac:raja-finished",false,false,data);
      window.dispatchEvent(ev);
    }
  }catch(e){console.warn("Raja account event error",e);}
}

function finishUp(won){
  playSound(won?"win":"lose");
  syncGlobals();renderList();renderAttempts();showResult(won);
  recordLocalStats(won);
  setTimeout(function(){renderStatsModal();$("statScrim").classList.add("show");},650);
  if(!IS_TESTER || currentDay<=TODAY_IDX){
    trackEvent({game:"zorta",puzzle_no:currentDay+1,puzzle_word:meta?meta.kategoria:"raja",won:won,tries:guessHistory.length,lang:lang,hint_used:!!hintData,mode:"daily"});
  }
  notifyRajaAccountFinished(won);
}
function showPreStart(){
  currentDay=0;
  window.currentDay=currentDay;
  var prev=$("prevDay"), next=$("nextDay");
  if(prev)prev.disabled=true;
  if(next)next.disabled=true;
  $("dayLabel").innerHTML="Raja<small>start 04.07.2026</small>";
  $("result").classList.remove("show");
  $("banner").style.display="none";
  $("list").innerHTML="";
  $("attempts").style.display="none";
  $("checkBtn").style.display="none";
  $("hintBar").style.display="none";
  showNotice('<div class="start-locked"><div class="big">Raja startuje jutro</div><div class="small">Pierwsza codzienna Raja rusza 04.07.2026. Od tego dnia będzie można wracać do archiwum, ale nie wcześniej niż do dnia 1.</div></div>');
}
function loadDay(d){
  if(!RAJA_STARTED){showPreStart();return;}
  d=Number(d);
  if(!isFinite(d))d=TODAY_IDX;
  d=Math.max(0,Math.floor(d));
  if(!IS_TESTER)d=Math.min(d,TODAY_IDX);
  currentDay=d;window.currentDay=currentDay;selIdx=-1;hintData=null;revealMap=null;revealOrder=null;
  $("result").classList.remove("show");$("banner").style.display="none";$("list").innerHTML="";$("checkBtn").style.display="none";$("attempts").style.display="none";
  updateDayNav();syncGlobals();
  rpc("zorta_daily_day",{p_day:currentDay}).then(function(m){
    hideNotice();meta=m;$("banner").style.display="block";setPuzzleHeader(m);
    var st=sanitizeState(loadState(currentDay),m.pozycje);
    if(st){order=st.order;guessHistory=st.history;status=st.status;hintData=st.hintData||null;}
    else{order=m.pozycje.slice();guessHistory=[];status="playing";hintData=null;clearState(currentDay);}
    syncGlobals();renderList();renderAttempts();
    if(status==="playing"){$("checkBtn").style.display="block";$("checkBtn").disabled=false;}
    else{
      recordLocalStats(status==="won");
      rpc("zorta_daily_reveal",{p_day:currentDay}).then(function(rv){revealMap=rv.wartosci;revealOrder=rv.kolejnosc;showResult(status==="won");}).catch(function(){showResult(status==="won");});
    }
  }).catch(function(err){
    console.warn("Raja daily load error",err);
    showNotice("<b>Nie udało się wczytać zagadki</b><br>Sprawdź, czy w Supabase został uruchomiony SQL <code>supabase-raja-daily-schema-seed-v88.sql</code> i czy funkcje RPC są dostępne.");
    toast(L().err);
  });
}
function updateDayNav(){
  if(!RAJA_STARTED){showPreStart();return;}
  var prev=$("prevDay"), next=$("nextDay");
  if(prev)prev.disabled=(currentDay<=0);
  if(next)next.disabled=(!IS_TESTER && currentDay>=TODAY_IDX);
  var tag=(currentDay===TODAY_IDX)?(" · "+L().today):(IS_TESTER&&currentDay>TODAY_IDX?(" · "+L().tester):"");
  $("dayLabel").innerHTML=L().day+" "+(currentDay+1)+"<small>"+(tag?tag.replace(" · ",""):"&nbsp;")+"</small>";
}
function buildShare(){
  var head="Raja #"+(currentDay+1);
  var score=(status==="won"?guessHistory.length:"X")+"/"+MAX_TRIES;
  var grid=guessHistory.map(function(m){return m.map(function(b){return b?"🟩":"⬜";}).join("");}).join("\n");
  return head+"\n"+score+"\n\n"+grid+"\n\n"+L().sharePrompt;
}
function copyText(txt){
  if(navigator.clipboard && window.isSecureContext)return navigator.clipboard.writeText(txt);
  return new Promise(function(resolve,reject){
    try{var ta=document.createElement("textarea");ta.value=txt;ta.setAttribute("readonly","");ta.style.position="fixed";ta.style.left="-9999px";ta.style.top="0";document.body.appendChild(ta);ta.focus();ta.select();var ok=document.execCommand("copy");document.body.removeChild(ta);ok?resolve():reject(new Error("copy"));}catch(e){reject(e);}
  });
}
function share(){
  var txt=buildShare();
  copyText(txt).then(function(){
    toast(L().copied);
    var b=$("shareBtn");if(b){var old=b.textContent;b.textContent=L().copied;setTimeout(function(){b.textContent=old||L().share;},1300);}
  }).catch(function(){toast(txt);});
}
var ICO={
  sun:'<svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><circle cx="8" cy="8" r="3.5"/><line x1="8" y1=".5" x2="8" y2="2.5"/><line x1="8" y1="13.5" x2="8" y2="15.5"/><line x1=".5" y1="8" x2="2.5" y2="8"/><line x1="13.5" y1="8" x2="15.5" y2="8"/><line x1="2.57" y1="2.57" x2="3.99" y2="3.99"/><line x1="12.01" y1="12.01" x2="13.43" y2="13.43"/><line x1="13.43" y1="2.57" x2="12.01" y2="3.99"/><line x1="3.99" y1="12.01" x2="2.57" y2="13.43"/></svg>',
  moon:'<svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M13.5 10.5a5.5 5.5 0 01-7.07-7.07A6 6 0 1013.5 10.5z"/></svg>'
};
function setBtn(id,on){var el=$(id);if(el)el.className=on?"on":"";}
function valOr(k,def){var v=store.get(k);return v==null||v===""?def:v;}
function applySettings(){
  var anim=valOr(ANIM_KEY,"on"),sound=valOr(SOUND_KEY,"off"),cb=valOr(CB_KEY,"off");
  document.documentElement.setAttribute("data-anim",anim);document.documentElement.setAttribute("data-sound",sound);document.documentElement.setAttribute("data-cb",cb);
  setBtn("animOn",anim==="on");setBtn("animOff",anim==="off");setBtn("soundOn",sound==="on");setBtn("soundOff",sound==="off");setBtn("cbOn",cb==="on");setBtn("cbOff",cb==="off");
}
function updateSettingsLabels(){
  var ids={settTitle:"settings",statTitle:"stats",animLabel:"anim",animSub:"animSub",soundLabel:"sound",soundSub:"soundSub",cbLabel:"cb",cbSub:"cbSub"};
  Object.keys(ids).forEach(function(id){if($(id))$(id).textContent=L()[ids[id]];});
  ["animOn","soundOn","cbOn"].forEach(function(id){if($(id))$(id).textContent=L().on;});
  ["animOff","soundOff","cbOff"].forEach(function(id){if($(id))$(id).textContent=L().off;});
  if($("hintBtn"))$("hintBtn").textContent=L().hintBtn;
}
var audioCtx=null;
function playSound(type){
  if(valOr(SOUND_KEY,"off")!=="on")return;
  try{audioCtx=audioCtx||new (window.AudioContext||window.webkitAudioContext)();var o=audioCtx.createOscillator(),g=audioCtx.createGain();var f={move:220,drop:280,check:360,hint:520,win:660,lose:150}[type]||300;o.type="sine";o.frequency.setValueAtTime(f,audioCtx.currentTime);g.gain.setValueAtTime(0.0001,audioCtx.currentTime);g.gain.exponentialRampToValueAtTime(0.045,audioCtx.currentTime+0.01);g.gain.exponentialRampToValueAtTime(0.0001,audioCtx.currentTime+0.11);o.connect(g);g.connect(audioCtx.destination);o.start();o.stop(audioCtx.currentTime+0.12);}catch(e){}
}
function applyTheme(t){document.documentElement.setAttribute("data-theme",t);store.set(THEME_KEY,t);$("themeBtn").innerHTML=(t==="dark")?ICO.sun:ICO.moon;}
function applyLang(){
  $("lPl").className=lang==="pl"?"on":"";
  $("lSzl").className=lang==="sl"?"on":"";
  $("tagline").textContent=L().tag;$("checkBtn").textContent=L().check;$("shareBtn").textContent=L().share;$("howTitle").textContent=L().howT;$("howBody").innerHTML=L().how;
  if(meta)setPuzzleHeader(meta);
  updateDayNav();renderAttempts();updateSettingsLabels();renderHint();
}
$("themeBtn").addEventListener("click",function(){applyTheme(document.documentElement.getAttribute("data-theme")==="dark"?"light":"dark");});
$("lPl").addEventListener("click",function(){lang="pl";store.set(LANG_KEY,"pl");applyLang();if(meta&&status!=="playing")showResult(status==="won");});
$("lSzl").addEventListener("click",function(){lang="sl";store.set(LANG_KEY,"szl");applyLang();if(meta&&status!=="playing")showResult(status==="won");});
$("helpBtn").addEventListener("click",function(){$("helpScrim").classList.add("show");});
$("helpClose").addEventListener("click",function(){$("helpScrim").classList.remove("show");});
$("helpScrim").addEventListener("click",function(e){if(e.target===$("helpScrim"))$("helpScrim").classList.remove("show");});
$("statBtn").addEventListener("click",function(){renderStatsModal();$("statScrim").classList.add("show");});
$("statClose").addEventListener("click",function(){$("statScrim").classList.remove("show");});
$("statScrim").addEventListener("click",function(e){if(e.target===$("statScrim"))$("statScrim").classList.remove("show");});
$("settBtn").addEventListener("click",function(){$("settScrim").classList.add("show");});
$("settClose").addEventListener("click",function(){$("settScrim").classList.remove("show");});
$("settScrim").addEventListener("click",function(e){if(e.target===$("settScrim"))$("settScrim").classList.remove("show");});
$("animOn").addEventListener("click",function(){store.set(ANIM_KEY,"on");applySettings();});
$("animOff").addEventListener("click",function(){store.set(ANIM_KEY,"off");applySettings();});
$("soundOn").addEventListener("click",function(){store.set(SOUND_KEY,"on");applySettings();playSound("hint");});
$("soundOff").addEventListener("click",function(){store.set(SOUND_KEY,"off");applySettings();});
$("cbOn").addEventListener("click",function(){store.set(CB_KEY,"on");applySettings();});
$("cbOff").addEventListener("click",function(){store.set(CB_KEY,"off");applySettings();});
$("hintBtn").addEventListener("click",useHint);
$("checkBtn").addEventListener("click",check);
$("shareBtn").addEventListener("click",share);
var prevBtn=$("prevDay"), nextBtn=$("nextDay");
if(prevBtn)prevBtn.addEventListener("click",function(){if(RAJA_STARTED&&currentDay>0)loadDay(currentDay-1);});
if(nextBtn)nextBtn.addEventListener("click",function(){if(RAJA_STARTED&&(IS_TESTER||currentDay<TODAY_IDX))loadDay(currentDay+1);});

applyTheme(store.get(THEME_KEY)==="dark"?"dark":"light");
applySettings();
applyLang();
loadConfig().then(function(){if(RAJA_STARTED)loadDay(TODAY_IDX);else showPreStart();}).catch(function(){showNotice("<b>Tryb podglądu niedostępny</b><br>Brak konfiguracji Supabase. Sprawdź plik <code>../config.js</code>.");});
console.info("Szpilplac raja/index.html v124 achievements audit fix");
})();
</script>

<script>
(function(){
  "use strict";
  var KEY = "szpilplac_cookie_consent_v1";
  function saveConsent(all){
    try{localStorage.setItem(KEY, JSON.stringify({required:true, all:!!all, saved_at:new Date().toISOString()}));}catch(e){}
    window.SZP_COOKIE_CONSENT = {required:true, all:!!all};
  }
  function readConsent(){
    try{var raw = localStorage.getItem(KEY); if(!raw)return null; return JSON.parse(raw);}catch(e){return null;}
  }
  function hideBanner(){var el = document.getElementById("cookieBanner"); if(el)el.hidden = true;}
  function showBanner(){var el = document.getElementById("cookieBanner"); if(el)el.hidden = false;}
  function bootCookies(){
    var current = readConsent();
    if(current){window.SZP_COOKIE_CONSENT = current; hideBanner();}
    else{showBanner();}
    var req = document.getElementById("cookieRequiredBtn");
    var all = document.getElementById("cookieAllBtn");
    if(req)req.addEventListener("click", function(){saveConsent(false); hideBanner();});
    if(all)all.addEventListener("click", function(){saveConsent(true); hideBanner();});
  }
  if(document.readyState === "loading")document.addEventListener("DOMContentLoaded", bootCookies);
  else bootCookies();
})();
</script>

