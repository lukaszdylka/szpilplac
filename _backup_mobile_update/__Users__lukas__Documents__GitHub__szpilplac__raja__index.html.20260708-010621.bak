<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Raja · Szpilplac · Familock</title>
<meta name="description" content="Codzienna śląska zagadka — poukładaj pięć rzeczy we właściwej kolejności. Gra od Familocka Starzik.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@500;700&family=Inter:wght@400;600;800&display=swap&subset=latin,latin-ext" rel="stylesheet">
<script src="../config.js?v=13"></script>
<style>
:root{
  --bg:#f0e8d4;--surface:#fbf7ee;--surface2:#f3ecda;--ink:#23201a;--ink2:#6a6150;
  --line:#c9bfa6;--green:#2f4a39;--gold:#bf8a3a;--correct:#3f8a5a;--miss:#b9b09a;
  --cbcorrect:#1a6fc4;--cbmiss:#6f7480;--wrong:#a14b3a;
}
[data-theme=light]{--bg:#f0e8d4;--surface:#fbf7ee;--surface2:#f3ecda;--ink:#23201a;--ink2:#6a6150;--line:#c9bfa6;--green:#2f4a39;--gold:#bf8a3a;--correct:#3f8a5a;--miss:#b9b09a;}
[data-theme=dark]{--bg:#161310;--surface:#262018;--surface2:#2e2820;--ink:#ede5d0;--ink2:#9a907a;--line:#3d3629;--green:#4a7a56;--gold:#d4a04a;--correct:#4a9a6a;--miss:#5a5448;--wrong:#d86d55}
[data-cb=on]{--correct:var(--cbcorrect);--miss:var(--cbmiss)}
*{box-sizing:border-box}
html,body{margin:0;padding:0}
body{font-family:"Inter",system-ui,sans-serif;color:var(--ink);background:var(--bg);-webkit-font-smoothing:antialiased;min-height:100vh}
button{font-family:inherit;cursor:pointer;border:none;background:none;color:inherit}
a{color:inherit;text-decoration:none}
.wrap{max-width:520px;margin:0 auto;padding:0 16px 48px;display:flex;flex-direction:column;min-height:100vh}
header{width:100%;padding:14px 2px 10px}
.topbar{display:flex;align-items:center;justify-content:space-between;gap:10px;margin-bottom:10px}
.back{font-size:12px;font-weight:700;color:var(--green);display:inline-flex;align-items:center;gap:4px}
[data-theme=dark] .back{color:var(--gold)}
.back:hover{text-decoration:underline}
.controls{display:flex;gap:5px;align-items:center;flex-wrap:wrap;justify-content:flex-end}
.lang-tog{display:flex;border:1px solid var(--line);border-radius:999px;overflow:hidden;background:var(--surface2)}
.lang-tog button{font-size:11px;font-weight:800;padding:5px 10px;color:var(--ink2)}
.lang-tog button.on{background:var(--green);color:#fff}
[data-theme=dark] .lang-tog button.on{background:var(--gold);color:#161310}
.icon-btn{width:32px;height:32px;border-radius:999px;border:1px solid var(--line);background:var(--surface2);display:flex;align-items:center;justify-content:center;color:var(--ink2)}
.icon-btn:hover{background:var(--surface);color:var(--ink)}
.icon-btn svg{display:block;flex:none}
.brand{margin-top:4px}
.brand h1{font-family:"Oswald";font-weight:700;text-transform:uppercase;letter-spacing:.08em;font-size:28px;margin:0;line-height:1}
.brand p{margin:3px 0 0;font-size:12px;color:var(--ink2);letter-spacing:.02em}
.daynav{display:flex;align-items:center;justify-content:center;gap:14px;margin:4px 0 14px}
.daynav button{width:34px;height:34px;border-radius:9px;border:1.5px solid var(--line);background:var(--surface);font-size:18px;color:var(--ink);line-height:1}
.daynav button[disabled]{opacity:.32;cursor:default}
.daynav .wk{font-family:"Oswald";font-size:15px;letter-spacing:.04em;color:var(--ink);text-align:center;min-width:150px}
.daynav .wk small{display:block;font-family:"Inter";font-weight:600;font-size:11px;color:var(--ink2);letter-spacing:0}
.banner{background:var(--surface);border:1.5px solid var(--line);border-radius:16px;padding:16px 16px 14px;margin-bottom:16px;position:relative;overflow:hidden}
.banner .eyebrow{font-family:"Oswald";font-weight:500;text-transform:uppercase;letter-spacing:.16em;font-size:11px;color:var(--gold)}
.banner .crit{font-family:"Oswald";font-weight:700;font-size:19px;margin:3px 0 10px;color:var(--ink);line-height:1.1}
.dir{display:flex;align-items:center;gap:10px;background:var(--surface2);border-radius:10px;padding:9px 12px;font-size:13px;color:var(--ink);line-height:1.3}
.dir .arrow{font-family:"Oswald";color:var(--green);font-size:20px;flex:none}
[data-theme=dark] .dir .arrow{color:var(--gold)}
.list{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:9px}
.row{display:flex;align-items:center;gap:11px;background:var(--surface);border:1.5px solid var(--line);border-radius:13px;padding:11px 12px;transition:border-color .15s,background .15s,transform .12s,opacity .12s}
.row.can-drag{cursor:grab;touch-action:none;user-select:none;-webkit-user-select:none}
.row.drag-source{opacity:.25;transform:scale(.985)}
.row.drop-target{border-color:var(--gold);background:var(--surface2);box-shadow:0 0 0 2px rgba(191,138,58,.18) inset}
.drag-ghost{position:fixed;left:0;top:0;z-index:1000;pointer-events:none;width:300px;box-shadow:0 18px 36px -18px rgba(0,0,0,.65);transform:rotate(-1deg) scale(1.03);opacity:.96;background:var(--surface)!important;border-color:var(--gold)!important}
.row.sel{border-color:var(--gold);background:var(--surface2)}
.row.fixed{border-color:var(--correct)}
.row.fixed .rank{background:var(--correct);color:#fff;border-color:var(--correct)}
.rank{font-family:"Oswald";font-weight:700;font-size:16px;width:30px;height:30px;flex:none;border:1.5px solid var(--line);border-radius:8px;display:grid;place-items:center;color:var(--ink2)}
.name{flex:1;min-width:0;font-weight:700;font-size:15px;line-height:1.2}
.val{font-family:"Oswald";font-weight:500;font-size:13px;color:var(--green);margin-left:6px;white-space:nowrap}
[data-theme=dark] .val{color:var(--gold)}
.arrows{display:flex;flex-direction:column;gap:2px;flex:none}
.arrows button{width:30px;height:18px;border:1.5px solid var(--line);border-radius:6px;background:var(--surface2);font-size:11px;line-height:1;color:var(--ink);display:grid;place-items:center}
.arrows button[disabled]{opacity:.3;cursor:default}
.tick{flex:none;width:20px;text-align:center;color:var(--correct);font-weight:800;font-size:16px}
.attempts{display:flex;align-items:center;justify-content:center;gap:7px;margin:16px 0 12px}
.attempts .dot{width:11px;height:11px;border-radius:50%;border:1.5px solid var(--line);background:transparent}
.attempts .dot.used{background:var(--miss);border-color:var(--miss)}
.attempts .lab{font-size:12px;color:var(--ink2);margin-left:4px}
.cta-check{width:100%;padding:14px;border-radius:13px;background:var(--green);color:#fbf7ee;font-family:"Oswald";font-weight:700;text-transform:uppercase;letter-spacing:.08em;font-size:16px}
.cta-check:active{transform:translateY(1px)}
.cta-check[disabled]{opacity:.5;cursor:default}
[data-theme=dark] .cta-check{color:#161310}
.result{margin-top:18px;background:var(--surface);border:1.5px solid var(--line);border-radius:16px;padding:18px;display:none}
.result.show{display:block}
.result h2{font-family:"Oswald";text-transform:uppercase;font-size:20px;margin:0 0 4px;color:var(--ink);letter-spacing:.04em}
.result .sub{font-size:13px;color:var(--ink2);margin-bottom:12px}
.result .src{display:none}
.share{margin-top:14px;width:100%;padding:12px;border-radius:12px;border:1.5px solid var(--green);color:var(--green);font-family:"Oswald";font-weight:700;text-transform:uppercase;letter-spacing:.06em;font-size:14px;background:transparent}
[data-theme=dark] .share{border-color:var(--gold);color:var(--gold)}
.hintbar{align-items:center;justify-content:center;gap:9px;margin:2px 0 12px;min-height:32px;text-align:center}
.hint-btn{display:inline-flex;align-items:center;justify-content:center;padding:9px 14px;border-radius:999px;border:1.5px solid var(--gold);color:var(--gold);background:transparent;font-size:12px;font-weight:800;text-transform:uppercase;letter-spacing:.05em}
.hint-btn:hover{background:var(--surface2)}
.hint-btn[disabled]{opacity:.45;cursor:default}
.hint-msg{font-size:13px;color:var(--ink2);font-weight:700;line-height:1.35}
.hint-msg b{color:var(--gold)}
.row.hinted{border-color:var(--gold);background:var(--surface2)}
.hinttag{font-size:10px;font-weight:800;letter-spacing:.05em;text-transform:uppercase;color:var(--gold);border:1px solid var(--gold);border-radius:999px;padding:3px 7px;white-space:nowrap}
.stats-body{display:flex;flex-direction:column;gap:14px;margin-top:6px}
.stats-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:8px}
.stat-card{background:var(--surface2);border:1px solid var(--line);border-radius:12px;padding:11px 12px}
.stat-card .n{font-family:"Oswald";font-size:25px;line-height:1;color:var(--green)}
[data-theme=dark] .stat-card .n{color:var(--gold)}
.stat-card .l{font-size:10px;font-weight:800;letter-spacing:.05em;text-transform:uppercase;color:var(--ink2);margin-top:2px}
.stat-dist{display:flex;flex-direction:column;gap:5px}
.stat-dist-row{display:flex;align-items:center;gap:8px;font-size:12px;color:var(--ink2)}
.stat-dist-i{width:18px;text-align:right;font-weight:800;color:var(--ink)}
.stat-dist-bar-wrap{flex:1;background:var(--surface2);border:1px solid var(--line);border-radius:999px;overflow:hidden;height:20px}
.stat-dist-bar{height:100%;background:var(--green);min-width:22px;color:#fff;font-size:10px;font-weight:800;display:flex;align-items:center;justify-content:flex-end;padding-right:7px}
[data-theme=dark] .stat-dist-bar{background:var(--gold);color:#161310}
.stat-note{font-size:12px;line-height:1.45;color:var(--ink2);text-align:center}
.stat-clear,.stat-share{width:100%;padding:10px 12px;border-radius:10px;border:1px solid var(--line);background:var(--surface2);color:var(--ink2);font-size:12px;font-weight:800;text-transform:uppercase;letter-spacing:.04em}
.stat-share{background:var(--green);border-color:var(--green);color:#fff}
.settings-body{display:flex;flex-direction:column;gap:0;margin-top:4px}
.sett-row{display:flex;align-items:center;justify-content:space-between;gap:12px;padding:12px 0;border-bottom:1px solid var(--line)}
.sett-row:last-child{border-bottom:none}
.sett-label{font-size:14px;color:var(--ink);font-weight:700}
.sett-sub{font-size:11.5px;color:var(--ink2);margin-top:2px;line-height:1.35}
.seg{display:flex;border:1px solid var(--line);border-radius:999px;overflow:hidden;background:var(--surface2);flex:none}
.seg button{font-size:11px;font-weight:800;padding:6px 10px;color:var(--ink2);white-space:nowrap}
.seg button.on{background:var(--green);color:#fff}
[data-theme=dark] .seg button.on{background:var(--gold);color:#161310}
[data-anim=off] *{transition:none!important;animation:none!important}
[data-anim=off] .drag-ghost{transform:none!important}
.scrim{position:fixed;inset:0;background:rgba(0,0,0,.45);display:none;align-items:center;justify-content:center;padding:20px;z-index:30}
.scrim.show{display:flex}
.modal{background:var(--surface);border:1.5px solid var(--line);border-radius:18px;padding:22px;max-width:420px;width:100%}
.modal h2{font-family:"Oswald";text-transform:uppercase;font-size:20px;margin:0 0 12px;color:var(--ink);letter-spacing:.04em}
.modal p{font-size:14px;line-height:1.5;color:var(--ink);margin:0 0 10px}
.modal .x{float:right;font-size:20px;color:var(--ink2);margin-top:-4px}
.toast{position:fixed;left:50%;bottom:28px;transform:translateX(-50%) translateY(20px);background:var(--ink);color:var(--bg);padding:10px 18px;border-radius:30px;font-size:13px;font-weight:600;opacity:0;pointer-events:none;transition:.25s;z-index:40}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
.notice{background:var(--surface);border:1.5px solid var(--line);border-radius:14px;padding:14px 15px;margin:0 0 14px;font-size:13px;line-height:1.45;color:var(--ink2);text-align:center}
.notice b{font-family:"Oswald";text-transform:uppercase;letter-spacing:.04em;color:var(--ink);font-size:15px}
.start-locked{display:grid;gap:10px;text-align:center}.start-locked .big{font-family:Oswald;text-transform:uppercase;font-size:22px;color:var(--ink)}.start-locked .small{font-size:13px;color:var(--ink2);line-height:1.45}
.foot{margin-top:auto;padding-top:22px;text-align:center}
.foot a{color:var(--green);font-weight:800;text-decoration:none;font-size:13px}
[data-theme=dark] .foot a{color:var(--gold)}

/* WSPÓLNA STOPKA SZPILPLAC */
.site-footer{
  width:100%;
  max-width:520px;
  margin:30px auto 0;
  padding:22px 12px 26px;
  text-align:center;
  color:var(--ink2);
  font-size:11.5px;
}
.footer-head{
  margin:0 0 4px;
  color:var(--ink);
  font-size:13px;
  font-weight:900;
}
.footer-copy{
  margin:0 0 12px;
  color:var(--ink2);
  font-size:11px;
  line-height:1.5;
}
.footer-news-btn{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  gap:6px;
  min-height:34px;
  margin:2px 0 12px;
  padding:8px 14px;
  border:1px solid rgba(191,138,58,.55);
  border-radius:999px;
  background:rgba(191,138,58,.12);
  color:var(--gold);
  font-size:12px;
  font-weight:900;
  letter-spacing:.02em;
}
.footer-news-btn:hover{
  background:rgba(191,138,58,.2);
  color:var(--ink);
  transform:translateY(-1px);
}
.footer-news-btn svg{flex:none}
.footer-icons{
  display:flex;
  justify-content:center;
  gap:10px;
  flex-wrap:wrap;
  margin-top:4px;
}
.footer-icons a{
  width:38px;
  height:38px;
  display:grid;
  place-items:center;
  border:1px solid var(--line);
  border-radius:999px;
  background:var(--surface2);
  color:var(--green);
}
.footer-icons a:hover{
  background:var(--surface);
  color:var(--gold);
  transform:translateY(-1px);
}
.footer-legal{
  display:flex;
  justify-content:center;
  gap:7px;
  flex-wrap:wrap;
  margin-top:12px;
  color:var(--ink2);
  font-size:11px;
  line-height:1.6;
  opacity:.84;
}
.footer-legal a{
  color:var(--ink2);
  font-weight:800;
}
.footer-legal a:hover{
  color:var(--green);
  text-decoration:underline;
}
.cookie-banner{
  position:fixed;
  left:16px;
  right:16px;
  bottom:16px;
  z-index:9998;
  display:grid;
  grid-template-columns:minmax(0,1fr) auto;
  gap:14px;
  align-items:center;
  max-width:980px;
  margin:0 auto;
  padding:14px 16px;
  border:1px solid var(--line);
  border-radius:18px;
  background:rgba(38,32,24,.96);
  color:#ede5d0;
  box-shadow:0 24px 70px -35px rgba(0,0,0,.75);
}
.cookie-banner[hidden]{display:none !important}
.cookie-banner__text strong{
  display:block;
  font-size:13px;
  margin-bottom:4px;
}
.cookie-banner__text p{
  margin:0;
  font-size:12px;
  line-height:1.5;
  color:#d1c5ad;
}
.cookie-banner__text a{
  display:inline-block;
  margin-top:6px;
  font-size:12px;
  font-weight:800;
  color:#fff;
  text-decoration:underline;
}
.cookie-banner__actions{
  display:flex;
  gap:8px;
  flex-wrap:wrap;
  justify-content:flex-end;
}
.cookie-btn{
  min-height:40px;
  border-radius:999px;
  border:1px solid #5a503d;
  padding:10px 14px;
  font-size:12px;
  font-weight:900;
}
.cookie-btn--ghost{
  background:transparent;
  color:#ede5d0;
}
.cookie-btn--solid{
  background:#4a7a56;
  color:#fff;
  border-color:#4a7a56;
}
.cookie-btn:hover{transform:translateY(-1px)}
.cookie-btn--ghost:hover{background:rgba(255,255,255,.05)}
.cookie-btn--solid:hover{filter:brightness(1.05)}
@media(max-width:760px){
  .cookie-banner{
    left:10px;
    right:10px;
    bottom:10px;
    grid-template-columns:1fr;
    gap:12px;
    padding:13px;
  }
  .cookie-banner__actions{justify-content:stretch}
  .cookie-btn{width:100%}
}

@media(max-width:430px){
  .wrap{padding-left:12px;padding-right:12px}
  .controls{gap:4px}
  .icon-btn{width:30px;height:30px}
  .daynav{gap:9px}
  .daynav .wk{min-width:128px}
  .row{padding:10px;gap:9px}
}

/* v99: podpowiedź i lista jako jeden pionowy blok */
.raja-stack{
  width:100%!important;
  max-width:none!important;
  display:flex!important;
  flex-direction:column!important;
  align-items:stretch!important;
  gap:12px!important;
  grid-column:1 / -1!important;
  clear:both!important;
  float:none!important;
}
.raja-stack #hintBar{
  order:1!important;
  width:100%!important;
  max-width:none!important;
  display:flex!important;
  justify-content:center!important;
  align-items:center!important;
  margin:0!important;
  padding:0!important;
  grid-column:1 / -1!important;
  clear:both!important;
  float:none!important;
}
.raja-stack #hintBtn,
.raja-stack .hint-btn{
  width:100%!important;
  max-width:100%!important;
  min-height:48px!important;
  margin:0!important;
}
.raja-stack #list{
  order:2!important;
  width:100%!important;
  max-width:none!important;
  display:flex!important;
  flex-direction:column!important;
  gap:9px!important;
  margin:0!important;
  padding:0!important;
  clear:both!important;
  float:none!important;
}
.raja-stack #list .row{
  width:100%!important;
}
#attempts,#checkBtn{
  clear:both!important;
  grid-column:1 / -1!important;
}


/* v100 canonical footer safety */
.site-footer .footer-nav{display:none!important}
.site-footer .footer-legal + .footer-legal{display:none!important}
.footer-news-btn{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  gap:6px;
  min-height:34px;
  margin:2px 0 12px;
  padding:8px 14px;
  border:1px solid rgba(191,138,58,.55);
  border-radius:999px;
  background:rgba(191,138,58,.12);
  color:var(--gold);
  font-size:12px;
  font-weight:900;
  letter-spacing:.02em;
}
.footer-news-btn:hover{background:rgba(191,138,58,.2);color:var(--ink);transform:translateY(-1px)}


/* v124 Raja: stabilniejsze układanie kolejności na telefonach */
.list{
  touch-action:manipulation!important;
}
.row{
  touch-action:manipulation!important;
  user-select:none!important;
  -webkit-user-select:none!important;
}
.row.selected,
.item.selected,
li.selected{
  outline:3px solid var(--gold)!important;
  outline-offset:2px!important;
  box-shadow:0 0 0 5px rgba(191,138,58,.16)!important;
}
.row .moveBtns,
.item .moveBtns,
li .moveBtns{
  display:flex;
  gap:5px;
  margin-left:auto;
  align-items:center;
}
.order-mini-btn{
  width:34px!important;
  height:34px!important;
  min-width:34px!important;
  border-radius:10px!important;
  border:1px solid var(--line)!important;
  background:var(--surface2)!important;
  color:var(--ink)!important;
  font-weight:900!important;
  font-size:14px!important;
  display:grid!important;
  place-items:center!important;
}
.order-mini-btn:disabled{
  opacity:.35!important;
  cursor:not-allowed!important;
}
.order-mobile-hint{
  margin:0 0 10px;
  padding:9px 11px;
  border:1px dashed rgba(191,138,58,.55);
  border-radius:12px;
  background:rgba(191,138,58,.08);
  color:var(--ink2);
  font-size:12px;
  line-height:1.35;
  text-align:center;
}
@media(pointer:fine){
  .order-mobile-hint{display:none}
}


/* v124 Raja: jeden prosty sposób przesuwania — strzałki ↑ ↓ */
.order-mobile-hint{
  margin:0 0 10px;
  padding:9px 11px;
  border:1px dashed rgba(191,138,58,.55);
  border-radius:12px;
  background:rgba(191,138,58,.08);
  color:var(--ink2);
  font-size:12px;
  line-height:1.35;
  text-align:center;
}
.row.selected,.item.selected,li.selected{
  outline:none!important;
  box-shadow:none!important;
}
.row,.item,li{
  touch-action:manipulation!important;
  user-select:none!important;
  -webkit-user-select:none!important;
}
.row .moveBtns,.item .moveBtns,li .moveBtns{
  display:flex;
  gap:5px;
  margin-left:auto;
  align-items:center;
}
.order-mini-btn{
  width:36px!important;
  height:34px!important;
  min-width:36px!important;
  border-radius:10px!important;
  border:1px solid var(--line)!important;
  background:var(--surface2)!important;
  color:var(--ink)!important;
  font-weight:900!important;
  font-size:14px!important;
  display:grid!important;
  place-items:center!important;
}
.order-mini-btn:disabled{
  opacity:.35!important;
  cursor:not-allowed!important;
}
body.raja-account-locked #list,
body.raja-account-locked .raja-stack{
  pointer-events:none!important;
  opacity:.62!important;
}
body.raja-account-locked .order-mini-btn,
body.raja-account-locked #checkBtn,
body.raja-account-locked #hintBtn{
  display:none!important;
}


/* SZPILPLAC RAJA MOBILE ARROWS ONLY v130 */
#settBtn{
  display:none!important;
}
#rajaOrderMobileHint{
  display:block;
  margin:0 0 10px;
  padding:10px 12px;
  border:1px dashed rgba(191,138,58,.55);
  border-radius:12px;
  background:rgba(191,138,58,.08);
  color:var(--ink2);
  font-size:12px;
  line-height:1.35;
  text-align:center;
}
.row.can-drag{
  cursor:default!important;
  touch-action:manipulation!important;
}
.row{
  touch-action:manipulation!important;
  user-select:none!important;
  -webkit-user-select:none!important;
}
.row.sel,
.row.selected,
.item.selected,
li.selected{
  outline:none!important;
  box-shadow:none!important;
}
.row.drag-source,
.row.drop-target,
.drag-ghost{
  display:none!important;
}
.row .moveBtns,
.item .moveBtns,
li .moveBtns{
  display:none!important;
}
.arrows{
  gap:6px!important;
}
.arrows button{
  width:46px!important;
  min-width:46px!important;
  height:40px!important;
  min-height:40px!important;
  border-radius:12px!important;
  font-size:18px!important;
  font-weight:900!important;
}
@media(max-width:430px){
  .wrap{padding-left:12px!important;padding-right:12px!important}
  .topbar{align-items:flex-start}
  .controls{gap:6px!important}
  .lang-tog button{min-height:36px!important;padding:7px 11px!important}
  .icon-btn{width:36px!important;height:36px!important}
  .brand h1{font-size:27px!important}
  .brand p{font-size:11.5px!important}
  .daynav button{width:42px!important;height:40px!important;font-size:24px!important}
  .daynav .wk{min-width:120px!important}
  .banner{padding:14px!important;margin-bottom:12px!important}
  .row{padding:10px 9px!important;gap:8px!important}
  .rank{width:30px!important;height:30px!important}
  .name{font-size:14px!important;line-height:1.22!important}
  .val{font-size:12px!important}
  .cta-check{min-height:52px!important;font-size:17px!important}
  .hint-btn{width:100%!important;min-height:48px!important}
}
</style>
</head>
<body>
<div class="wrap">
  <header>
    <div class="topbar">
      <a class="back" href="../index.html">← Szpilplac</a>
      <div class="controls">
        <div class="lang-tog" role="group" aria-label="Język">
          <button id="lPl" class="on">PL</button>
          <button id="lSzl">ŚL</button>
        </div>
        <button class="icon-btn" id="themeBtn" title="Motyw" aria-label="Zmień motyw"></button>
        <button class="icon-btn" id="helpBtn" title="Jak grać" aria-label="Jak grać">
          <svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><circle cx="8" cy="8" r="6.5"/><path d="M6 6.5a2 2 0 113 1.73c-.6.35-1 .97-1 1.77"/><circle cx="8" cy="12" r=".7" fill="currentColor" stroke="none"/></svg>
        </button>

        <button class="icon-btn" id="settBtn" title="Ustawienia" aria-label="Ustawienia">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M9.4 4.01 8.51 1.25h6.98l-.89 2.76 1.21.51 1.32-2.59 4.94 4.94-2.59 1.32.51 1.21 2.76-.89v6.98l-2.76-.89-.51 1.21 2.59 1.32-4.94 4.94-1.32-2.59-1.21.51.89 2.76H8.51l.89-2.76-1.21-.51-1.32 2.59-4.94-4.94 2.59-1.32-.51-1.21-2.76.89V8.51l2.76.89.51-1.21-2.59-1.32 4.94-4.94 1.32 2.59z"/><circle cx="12" cy="12" r="4.4"/></svg>
        </button>
        <button class="icon-btn" id="statBtn" title="Statystyki" aria-label="Statystyki">
          <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor"><rect x="1" y="9" width="3" height="6" rx=".8"/><rect x="6.5" y="5" width="3" height="10" rx=".8"/><rect x="12" y="2" width="3" height="13" rx=".8"/></svg>
        </button>
      </div>
    </div>
    <div class="brand">
      <h1>Raja</h1>
      <p id="tagline">Codzienna śląska zagadka — poukładaj</p>
    </div>
  </header>

  <nav class="daynav" aria-label="Nawigacja dnia">
    <button id="prevDay" type="button" aria-label="Poprzedni dzień">‹</button>
    <div class="wk" id="dayLabel">Dzień —<small></small></div>
    <button id="nextDay" type="button" aria-label="Następny dzień">›</button>
  </nav>

  <div id="notice" class="notice" style="display:none"></div>

  <section id="banner" class="banner" style="display:none">
    <div class="eyebrow" id="eyebrow">Kategoria</div>
    <div class="crit" id="crit">Ułóż według</div>
    <div class="dir"><span id="dirArrow" class="arrow">↓</span><span id="dirText">od najmniejszej wartości do największej</span></div>
  </section>

  <section class="raja-stack" aria-label="Układanie kolejności">
    <div id="hintBar" class="hintbar" style="display:none">
    <button id="hintBtn" class="hint-btn" type="button">Pokaż podpowiedź</button>
    <div id="hintMsg" class="hint-msg"></div>
  </div>
    <div id="rajaOrderMobileHint" class="order-mobile-hint">Użyj strzałek ↑ ↓ przy kafelkach. To jedyny sposób zmiany kolejności.</div>
    <ol id="list" class="list"></ol>
  </section>
<div id="attempts" class="attempts"></div>
  <button id="checkBtn" class="cta-check" type="button" style="display:none">Sprawdź</button>

  <section id="result" class="result">
    <h2 id="resTitle">Poukładane!</h2>
    <div id="resSub" class="sub"></div>
    <ol id="resList" class="list"></ol>
    <div id="resSrc" class="src"></div>
    <button id="shareBtn" class="share" type="button">Podziel się wynikiem</button>
  </section>

  <footer class="site-footer" data-footer-normalized="static-v100">
  <div class="footer-head">Szpilplac i Familock</div>
  <div class="footer-copy">Zajrzyj też do naszych miejsc i ważnych informacji.</div>

  <a class="footer-news-btn" href="../nowosci.html" aria-label="Zobacz nowości w Szpilplacu">
    <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 15.5V4.5A1.5 1.5 0 015.5 3h9A1.5 1.5 0 0116 4.5v11A1.5 1.5 0 0114.5 17h-9A1.5 1.5 0 014 15.5z"/><path d="M7 7h6M7 10h6M7 13h3"/></svg>
    Co nowego?
  </a>

