:root{--bg:#f0e8d4;--surface:#fbf7ee;--surface2:#f3ecda;--ink:#23201a;--ink2:#6a6150;--line:#c9bfa6;--green:#2f4a39;--gold:#bf8a3a;--sh:0 6px 18px -10px rgba(35,32,26,.4)}
[data-theme=dark]{--bg:#161310;--surface:#262018;--surface2:#2e2820;--ink:#ede5d0;--ink2:#9a907a;--line:#3d3629;--green:#4a7a56;--gold:#d4a04a;--sh:0 6px 18px -10px rgba(0,0,0,.5)}
*{box-sizing:border-box}
html,body{margin:0;min-height:100%}
body{font-family:"Inter",system-ui,sans-serif;color:var(--ink);background:var(--bg);display:flex;flex-direction:column;align-items:center;padding:0 16px 42px;line-height:1.58}
a{color:var(--green);font-weight:800;text-decoration:none}
a:hover{text-decoration:underline}
header,main,footer{width:100%;max-width:780px}
header{padding-top:22px;margin-bottom:14px}
.topbar{display:flex;align-items:center;justify-content:space-between;gap:12px}
.back{display:inline-flex;align-items:center;gap:6px;font-size:13px;color:var(--green);font-weight:900}
.brand{font-family:"Oswald";font-size:clamp(30px,7vw,48px);line-height:.98;text-transform:uppercase;margin-top:14px}
.sub{font-size:13px;color:var(--ink2);margin-top:6px}
.card{background:var(--surface);border:1px solid var(--line);border-radius:16px;box-shadow:var(--sh);padding:22px;margin:12px 0}
h1,h2,h3{font-family:"Oswald";text-transform:uppercase;letter-spacing:.03em;line-height:1.06;color:var(--ink)}
h1{font-size:34px;margin:0 0 8px}
h2{font-size:23px;margin:28px 0 10px}
h3{font-size:17px;margin:18px 0 7px}
p{margin:0 0 12px}
ul,ol{padding-left:22px;margin:0 0 14px}
li{margin:5px 0}
.meta{font-size:12px;color:var(--ink2);margin-bottom:12px}
.toc{display:flex;flex-wrap:wrap;gap:8px;margin:14px 0 4px}
.toc a{font-size:12px;border:1px solid var(--line);border-radius:999px;padding:7px 10px;background:var(--surface2)}
.notice{background:var(--surface2);border:1px dashed var(--line);border-radius:12px;padding:13px 14px;color:var(--ink2);font-size:13px}
.table{overflow:auto;border:1px solid var(--line);border-radius:12px;margin:12px 0 16px}
table{width:100%;border-collapse:collapse;background:var(--surface2);font-size:13px}
th,td{padding:10px 11px;border-bottom:1px solid var(--line);text-align:left;vertical-align:top}
th{font-size:11px;text-transform:uppercase;letter-spacing:.04em;color:var(--ink2)}
tr:last-child td{border-bottom:0}
footer{text-align:center;color:var(--ink2);font-size:12px;margin-top:18px;line-height:1.8}
footer nav{display:flex;justify-content:center;gap:10px;flex-wrap:wrap;margin:8px 0}
small{color:var(--ink2)}
@media(max-width:560px){.card{padding:17px}.table{font-size:12px}th,td{padding:9px 8px}.topbar{align-items:flex-start;flex-direction:column}}
</style>
